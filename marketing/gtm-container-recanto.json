{
  "exportFormatVersion": 2,
  "containerVersion": {
    "container": {
      "accountId": "0",
      "containerId": "0",
      "name": "Recanto Eventos",
      "publicId": "GTM-K5DK33L3",
      "usageContext": ["WEB"]
    },
    "builtInVariable": [
      { "accountId": "0", "containerId": "0", "type": "CLICK_URL", "name": "Click URL" },
      { "accountId": "0", "containerId": "0", "type": "EVENT", "name": "Event" },
      { "accountId": "0", "containerId": "0", "type": "PAGE_URL", "name": "Page URL" }
    ],
    "variable": [
      {
        "accountId": "0", "containerId": "0", "variableId": "1",
        "name": "GA4 Measurement ID", "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "G-K3SWZDFF95" }],
        "notes": "ID de medicao do GA4 do Recanto Eventos."
      },
      {
        "accountId": "0", "containerId": "0", "variableId": "2",
        "name": "AW Conversion ID", "type": "c",
        "parameter": [{ "type": "TEMPLATE", "key": "value", "value": "AW-XXXXXXXXX" }],
        "notes": "PREENCHER: ID de conversao do Google Ads (igual para as 4 acoes; o rotulo e que muda)."
      },
      {
        "accountId": "0", "containerId": "0", "variableId": "3",
        "name": "DLV - value", "type": "v",
        "parameter": [
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" },
          { "type": "BOOLEAN", "key": "setDefaultValue", "value": "false" },
          { "type": "TEMPLATE", "key": "name", "value": "value" }
        ]
      },
      {
        "accountId": "0", "containerId": "0", "variableId": "4",
        "name": "DLV - currency", "type": "v",
        "parameter": [
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" },
          { "type": "BOOLEAN", "key": "setDefaultValue", "value": "true" },
          { "type": "TEMPLATE", "key": "defaultValue", "value": "BRL" },
          { "type": "TEMPLATE", "key": "name", "value": "currency" }
        ]
      },
      {
        "accountId": "0", "containerId": "0", "variableId": "5",
        "name": "DLV - transaction_id", "type": "v",
        "parameter": [
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" },
          { "type": "BOOLEAN", "key": "setDefaultValue", "value": "false" },
          { "type": "TEMPLATE", "key": "name", "value": "transaction_id" }
        ]
      },
      {
        "accountId": "0", "containerId": "0", "variableId": "6",
        "name": "DLV - pacote", "type": "v",
        "parameter": [
          { "type": "INTEGER", "key": "dataLayerVersion", "value": "2" },
          { "type": "BOOLEAN", "key": "setDefaultValue", "value": "false" },
          { "type": "TEMPLATE", "key": "name", "value": "pacote" }
        ]
      }
    ],
    "trigger": [
      {
        "accountId": "0", "containerId": "0", "triggerId": "1",
        "name": "CE - reserva_paga", "type": "CUSTOM_EVENT",
        "customEventFilter": [
          { "type": "EQUALS", "parameter": [
            { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
            { "type": "TEMPLATE", "key": "arg1", "value": "reserva_paga" }
          ]}
        ]
      },
      {
        "accountId": "0", "containerId": "0", "triggerId": "2",
        "name": "CE - envio_formulario", "type": "CUSTOM_EVENT",
        "customEventFilter": [
          { "type": "EQUALS", "parameter": [
            { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
            { "type": "TEMPLATE", "key": "arg1", "value": "envio_formulario" }
          ]}
        ]
      },
      {
        "accountId": "0", "containerId": "0", "triggerId": "3",
        "name": "CE - inicio_checkout", "type": "CUSTOM_EVENT",
        "customEventFilter": [
          { "type": "EQUALS", "parameter": [
            { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
            { "type": "TEMPLATE", "key": "arg1", "value": "inicio_checkout" }
          ]}
        ]
      },
      {
        "accountId": "0", "containerId": "0", "triggerId": "4",
        "name": "CE - selecao_pacote", "type": "CUSTOM_EVENT",
        "customEventFilter": [
          { "type": "EQUALS", "parameter": [
            { "type": "TEMPLATE", "key": "arg0", "value": "{{_event}}" },
            { "type": "TEMPLATE", "key": "arg1", "value": "selecao_pacote" }
          ]}
        ]
      },
      {
        "accountId": "0", "containerId": "0", "triggerId": "5",
        "name": "Click - WhatsApp", "type": "LINK_CLICK",
        "filter": [
          { "type": "CONTAINS", "parameter": [
            { "type": "TEMPLATE", "key": "arg0", "value": "{{Click URL}}" },
            { "type": "TEMPLATE", "key": "arg1", "value": "wa.me" }
          ]}
        ],
        "waitForTags": { "type": "BOOLEAN", "value": "false" },
        "checkValidation": { "type": "BOOLEAN", "value": "false" },
        "waitForTagsTimeout": { "type": "TEMPLATE", "value": "2000" },
        "uniqueTriggerId": { "type": "TEMPLATE", "value": "5_wa" }
      }
    ],
    "tag": [
      {
        "accountId": "0", "containerId": "0", "tagId": "1",
        "name": "Conversion Linker", "type": "gclidw",
        "parameter": [{ "type": "BOOLEAN", "key": "enableCrossDomain", "value": "false" }],
        "firingTriggerId": ["2147479553"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "2",
        "name": "GA4 - Configuracao (Google tag)", "type": "googtag",
        "parameter": [{ "type": "TEMPLATE", "key": "tagId", "value": "{{GA4 Measurement ID}}" }],
        "firingTriggerId": ["2147479553"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "3",
        "name": "GA4 - purchase", "type": "gaawe",
        "parameter": [
          { "type": "TEMPLATE", "key": "eventName", "value": "purchase" },
          { "type": "TEMPLATE", "key": "measurementId", "value": "{{GA4 Measurement ID}}" },
          { "type": "LIST", "key": "eventSettingsTable", "list": [
            { "type": "MAP", "map": [
              { "type": "TEMPLATE", "key": "parameter", "value": "currency" },
              { "type": "TEMPLATE", "key": "parameterValue", "value": "{{DLV - currency}}" }
            ]},
            { "type": "MAP", "map": [
              { "type": "TEMPLATE", "key": "parameter", "value": "value" },
              { "type": "TEMPLATE", "key": "parameterValue", "value": "{{DLV - value}}" }
            ]},
            { "type": "MAP", "map": [
              { "type": "TEMPLATE", "key": "parameter", "value": "transaction_id" },
              { "type": "TEMPLATE", "key": "parameterValue", "value": "{{DLV - transaction_id}}" }
            ]}
          ]}
        ],
        "firingTriggerId": ["1"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "4",
        "name": "GA4 - generate_lead", "type": "gaawe",
        "parameter": [
          { "type": "TEMPLATE", "key": "eventName", "value": "generate_lead" },
          { "type": "TEMPLATE", "key": "measurementId", "value": "{{GA4 Measurement ID}}" },
          { "type": "LIST", "key": "eventSettingsTable", "list": [
            { "type": "MAP", "map": [
              { "type": "TEMPLATE", "key": "parameter", "value": "currency" },
              { "type": "TEMPLATE", "key": "parameterValue", "value": "{{DLV - currency}}" }
            ]},
            { "type": "MAP", "map": [
              { "type": "TEMPLATE", "key": "parameter", "value": "value" },
              { "type": "TEMPLATE", "key": "parameterValue", "value": "{{DLV - value}}" }
            ]}
          ]}
        ],
        "firingTriggerId": ["2"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "5",
        "name": "Google Ads - Reserva paga", "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{AW Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "COLE_ROTULO_RESERVA" },
          { "type": "TEMPLATE", "key": "conversionValue", "value": "{{DLV - value}}" },
          { "type": "TEMPLATE", "key": "currencyCode", "value": "{{DLV - currency}}" },
          { "type": "TEMPLATE", "key": "orderId", "value": "{{DLV - transaction_id}}" },
          { "type": "BOOLEAN", "key": "enableConversionLinker", "value": "true" }
        ],
        "firingTriggerId": ["1"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "6",
        "name": "Google Ads - Lead", "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{AW Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "COLE_ROTULO_LEAD" },
          { "type": "TEMPLATE", "key": "conversionValue", "value": "{{DLV - value}}" },
          { "type": "TEMPLATE", "key": "currencyCode", "value": "{{DLV - currency}}" },
          { "type": "BOOLEAN", "key": "enableConversionLinker", "value": "true" }
        ],
        "firingTriggerId": ["2"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "7",
        "name": "Google Ads - Inicio checkout", "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{AW Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "COLE_ROTULO_CHECKOUT" },
          { "type": "BOOLEAN", "key": "enableConversionLinker", "value": "true" }
        ],
        "firingTriggerId": ["3"],
        "tagFiringOption": "ONCE_PER_EVENT"
      },
      {
        "accountId": "0", "containerId": "0", "tagId": "8",
        "name": "Google Ads - Contato WhatsApp", "type": "awct",
        "parameter": [
          { "type": "TEMPLATE", "key": "conversionId", "value": "{{AW Conversion ID}}" },
          { "type": "TEMPLATE", "key": "conversionLabel", "value": "COLE_ROTULO_CONTATO" },
          { "type": "BOOLEAN", "key": "enableConversionLinker", "value": "true" }
        ],
        "firingTriggerId": ["5"],
        "tagFiringOption": "ONCE_PER_EVENT"
      }
    ]
  }
}
